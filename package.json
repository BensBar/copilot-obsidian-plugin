{
  "name": "obsidian-copilot",
  "version": "1.3.0",
  "description": "GitHub Copilot AI assistant for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "github-copilot",
    "ai"
  ],
  "author": "BensBar",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.27.4",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "~5.6.0"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.1"
  }
}
